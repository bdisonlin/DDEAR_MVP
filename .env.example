# ── Simulation Service ────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000

# PostgreSQL — persistent store for baselines and tariff presets
# Optional: if unset, service runs in in-memory mode (data lost on restart)
DATABASE_URL=postgresql://ddear:ddear_dev@localhost:5432/ddear

# Redis — hot cache for baselines (24 h TTL)
# Optional: if unset, cache is disabled (no performance impact for small scale)
REDIS_URL=redis://localhost:6379/0

# ── Data Service (Go) ─────────────────────────────────────────────────────────
DATA_DIR=/data/uploads

# ── Frontend (Vite dev server) ────────────────────────────────────────────────
# Override API base URLs if running services on different ports/hosts
VITE_SIMULATION_API_URL=http://localhost:8000/api/v1
VITE_DATA_API_URL=http://localhost:8080/api/v1
